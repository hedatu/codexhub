{
  "name": "codexhub",
  "version": "0.3.3",
  "private": false,
  "type": "module",
  "description": "Cloud relay dashboard for multiple Farfield/Codex desktop nodes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hedatu/codexhub.git"
  },
  "homepage": "https://github.com/hedatu/codexhub#readme",
  "keywords": [
    "codex",
    "farfield",
    "dashboard",
    "pwa",
    "remote-control",
    "caddy",
    "rustdesk-inspired"
  ],
  "scripts": {
    "start": "node src/server/cloud-server.mjs",
    "dev:server": "node --watch src/server/cloud-server.mjs",
    "agent": "node src/desktop-agent/agent.mjs",
    "smoke": "node scripts/smoke.mjs",
    "package:release": "powershell -ExecutionPolicy Bypass -File scripts/package-release.ps1",
    "build:companion": "powershell -ExecutionPolicy Bypass -File scripts/build-companion.ps1",
    "build:android": "powershell -ExecutionPolicy Bypass -File scripts/build-android-twa.ps1"
  },
  "engines": {
    "node": ">=20"
  }
}
