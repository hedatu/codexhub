CODEXHUB_PORT=8787
CODEXHUB_HOST=0.0.0.0
CODEXHUB_PUBLIC_URL=https://hub.example.com
CODEXHUB_ADMIN_TOKEN=change-me-long-random-admin-token
CODEXHUB_INSTALL_KEY=change-me-install-key-for-new-computers
CODEXHUB_DATA_FILE=./codexhub-state.json
CODEXHUB_STORAGE=sqlite
CODEXHUB_SQLITE_FILE=./data/codexhub.db
CODEXHUB_SQLITE_MIN_PERSIST_MS=15000
CODEXHUB_BACKUP_DIR=./backups
CODEXHUB_BACKUP_RETENTION_DAYS=30
CODEXHUB_REPORT_TZ_OFFSET_MINUTES=480

# Optional FCM HTTP v1 push:
# CODEXHUB_FCM_SERVICE_ACCOUNT_FILE=/opt/codexhub/secrets/firebase-service-account.json
# CODEXHUB_FCM_PROJECT_ID=your-firebase-project-id
# CODEXHUB_FIREBASE_WEB_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","messagingSenderId":"...","appId":"..."}
# CODEXHUB_FIREBASE_VAPID_KEY=your-web-push-vapid-key

# Desktop agent example:
# CODEXHUB_SERVER=https://hub.example.com
# CODEXHUB_NODE_ID=TMT1
# CODEXHUB_NODE_NAME=TMT1
# CODEXHUB_INSTALL_KEY=change-me-install-key-for-new-computers
# CODEXHUB_NODE_KEY=returned-by-enrollment-and-stored-in-agent-json
# FARFIELD_URL=http://127.0.0.1:4311
# CODEXHUB_INTERVAL_MS=5000
